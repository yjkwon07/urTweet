term'] ? 'error' : 'success'}\n        help={errors['user-term'] ? errors['user-term']?.message : ''}\n        rules={[{ message: errors['user-term']?.message }]}\n      >\n        <Controller\n          control={control}\n          render={({ value, onChange }) => (\n            <Checkbox onChange={() => onChange(!value)} checked={value} value={value}>\n              약관에 동의 합니다.\n            </Checkbox>\n          )}\n          name=\"user-term\"\n          id=\"user-term\"\n          defaultValue={false}\n        />\n      </Form.Item>\n      <Form.Item name=\"submit\">\n        <Button type=\"primary\" htmlType=\"submit\" loading={status === 'LOADING'}>\n          가입하기\n        </Button>\n      </Form.Item>\n    </FormWrapper>\n  );\n};\n\nexport default Signup;\n","import React from 'react';\n\nimport Head from 'next/head';\n\nimport SEO, { IProps as ISEOProps } from '@components/SEO';\nimport AppLayout from '@layouts/App';\nimport { SIGNUP_URL } from '@utils/urls';\nimport Signup from '@views/Signup';\n\nexport interface IProps {\n  title: string;\n  seo: ISEOProps;\n}\n\nconst SignupPage = ({ title, seo }: IProps) => {\n  return (\n    <AppLayout>\n      <Head>\n        <title>{title}</title>\n        <SEO title={seo.title} url={seo.url} description={seo.description} name={seo.name} keywords={seo.keywords} />\n      </Head>\n      <Signup />\n    </AppLayout>\n  );\n};\n\n// Static Generation\nexport async function getStaticProps() {\n  return {\n    props: {\n      title: `회원가입 | urTweet`,\n      seo: {\n        title: `회원가입`,\n        url: SIGNUP_URL,\n        description: `urTweet 회원가입`,\n        name: `urTweet 회원가입`,\n        keywords: `회원가입`,\n      },\n    },\n  };\n}\n\nexport default SignupPage;\n"]}}