   .addCase(login.success, (state, { payload: data }) => {\n        state.MyInfo = data;\n      }) \n      .addCase(logout.success, (state) => {\n        state.MyInfo = null;\n      })\n      .addDefaultCase(() => {}),\n});\n\nexport const userReducer = slice.reducer;\nexport const userAction = slice.actions;\n"]},"metadata":{},"sourceType":"module"}