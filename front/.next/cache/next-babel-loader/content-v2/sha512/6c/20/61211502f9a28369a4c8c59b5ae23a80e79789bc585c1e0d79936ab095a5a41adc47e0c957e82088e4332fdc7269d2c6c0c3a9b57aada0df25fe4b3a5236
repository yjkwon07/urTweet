  onSearch={handleSubmit}\n              loading={status === 'LOADING'}\n            />\n          }\n          name=\"nickname\"\n          id=\"nickname\"\n          placeholder={myData?.nickname}\n          defaultValue=\"\"\n        />\n      </Form.Item>\n    </FormWrapper>\n  );\n};\n\nexport default NicknameEditForm;\n"]},"metadata":{},"sourceType":"module"}