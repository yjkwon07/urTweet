{"ast":null,"code":"import { configureStore } from '@reduxjs/toolkit';\nimport { createWrapper } from 'next-redux-wrapper';\nimport createSagaMiddleware from 'redux-saga';\nimport thunkMiddleware from 'redux-thunk';\nimport rootSaga from './sagas';\nimport rootReducer from './slices';\nconst devMode = false; // Next.js를 사용하게 되면 유저가 요청할 때 마다 redux store를 새로 생성하게 되므로 redux store가 여러 개가 될 수 있다.\n// etInitialProps, getServerSideProps 등에서 redux store에 접근할 수 있어야 하는데 그것을 next-redux-wrapper가 도와준다.\n\nconst makeStore = () => {\n  const sagaMiddleware = createSagaMiddleware();\n  const store = configureStore({\n    reducer: rootReducer,\n    middleware: [thunkMiddleware, sagaMiddleware],\n    devTools: devMode\n  }); // Next Redux Toolkit 에서 saga를 사용해야할 때\n\n  store.sagaTask = sagaMiddleware.run(rootSaga);\n  return store;\n};\n\nexport const wrapper = createWrapper(makeStore, {\n  debug: devMode\n});","map":{"version":3,"sources":["C:/Users/권영준/Desktop/urTweet-front/urTweet/front/modules/store/configStore.ts"],"names":["configureStore","createWrapper","createSagaMiddleware","thunkMiddleware","rootSaga","rootReducer","devMode","makeStore","sagaMiddleware","store","reducer","middleware","devTools","sagaTask","run","wrapper","debug"],"mappings":"AAAA,SAASA,cAAT,QAA+B,kBAA/B;AACA,SAASC,aAAT,QAAyC,oBAAzC;AACA,OAAOC,oBAAP,MAAiC,YAAjC;AACA,OAAOC,eAAP,MAA4B,aAA5B;AAEA,OAAOC,QAAP,MAAqB,SAArB;AACA,OAAOC,WAAP,MAAuC,UAAvC;AAEA,MAAMC,OAAO,QAAb,C,CAEA;AACA;;AACA,MAAMC,SAA+B,GAAG,MAAM;AAC5C,QAAMC,cAAc,GAAGN,oBAAoB,EAA3C;AACA,QAAMO,KAAK,GAAGT,cAAc,CAAC;AAC3BU,IAAAA,OAAO,EAAEL,WADkB;AAE3BM,IAAAA,UAAU,EAAE,CAACR,eAAD,EAAkBK,cAAlB,CAFe;AAG3BI,IAAAA,QAAQ,EAAEN;AAHiB,GAAD,CAA5B,CAF4C,CAO5C;;AACAG,EAAAA,KAAK,CAACI,QAAN,GAAiBL,cAAc,CAACM,GAAf,CAAmBV,QAAnB,CAAjB;AACA,SAAOK,KAAP;AACD,CAVD;;AAYA,OAAO,MAAMM,OAAO,GAAGd,aAAa,CAACM,SAAD,EAAY;AAC9CS,EAAAA,KAAK,EAAEV;AADuC,CAAZ,CAA7B","sourcesContent":["import { configureStore } from '@reduxjs/toolkit';\nimport { createWrapper, MakeStore } from 'next-redux-wrapper';\nimport createSagaMiddleware from 'redux-saga';\nimport thunkMiddleware from 'redux-thunk';\n\nimport rootSaga from './sagas';\nimport rootReducer, { RootState } from './slices';\n\nconst devMode = process.env.NODE_ENV === 'development';\n\n// Next.js를 사용하게 되면 유저가 요청할 때 마다 redux store를 새로 생성하게 되므로 redux store가 여러 개가 될 수 있다.\n// etInitialProps, getServerSideProps 등에서 redux store에 접근할 수 있어야 하는데 그것을 next-redux-wrapper가 도와준다.\nconst makeStore: MakeStore<RootState> = () => {\n  const sagaMiddleware = createSagaMiddleware();\n  const store = configureStore({\n    reducer: rootReducer,\n    middleware: [thunkMiddleware, sagaMiddleware],\n    devTools: devMode,\n  });\n  // Next Redux Toolkit 에서 saga를 사용해야할 때\n  store.sagaTask = sagaMiddleware.run(rootSaga);\n  return store;\n};\n\nexport const wrapper = createWrapper(makeStore, {\n  debug: devMode,\n});\n"]},"metadata":{},"sourceType":"module"}