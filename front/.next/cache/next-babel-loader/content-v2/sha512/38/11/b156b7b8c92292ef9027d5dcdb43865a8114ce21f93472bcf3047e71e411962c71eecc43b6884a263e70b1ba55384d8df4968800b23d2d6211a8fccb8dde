s';\n\nconst UserProfile = () => {\n  const dispatch = useDispatch();\n  const {} = useFetchStatus(login.TYPE);\n  const myData = useSelector(userSelector.myData);\n\n  const handleLogout = useCallback(() => {\n    dispatch(logout.requset({}));\n  }, [dispatch]);\n\n  if (!myData) return null;\n  return (\n    <Card\n      actions={[\n        <div key=\"twit\">\n          <Link href={GET_USER_URL(myData.id.toString())} passHref>\n            <a href={PASS_HREF}>\n              게시글\n              <br />\n              {myData.Posts?.length}\n            </a>\n          </Link>\n        </div>,\n        <div key=\"followings\">\n          <Link href={PROFILE_URL} passHref>\n            <a href={PASS_HREF}>\n              팔로잉\n              <br />\n              {myData.Followings.length}\n            </a>\n          </Link>\n        </div>,\n        <div key=\"followings\">\n          <Link href={PROFILE_URL} passHref>\n            <a href={PASS_HREF}>\n              팔로워\n              <br />\n              {myData.Followers?.length}\n            </a>\n          </Link>\n        </div>,\n      ]}\n    >\n      <Card.Meta\n        avatar={\n          <Link href={GET_USER_URL(myData.id.toString())}>\n            <Avatar>{myData.nickname}</Avatar>\n          </Link>\n        }\n        title={myData.nickname}\n      />\n      <Button style={{ marginTop: 15 }} onClick={handleLogout}>\n        <LogoutOutlined />\n        로그아웃\n      </Button>\n    </Card>\n  );\n};\n\nexport default UserProfile;\n"]},"metadata":{},"sourceType":"module"}