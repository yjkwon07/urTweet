= createRequestAction(`${POST}/modifyPost`, requestModifyPost);\nexport const removePost = createRequestAction(`${POST}/removePost`, requestRemovePost);\nexport const likePost = createRequestAction(`${POST}/likePost`, requestLikePost);\nexport const unlikePost = createRequestAction(`${POST}/unlikePost`, requestUnlikePost);\nexport const createComment = createRequestAction(`${POST}/createComment`, requestCreateComment);\n\n// Type\nexport interface IState {\n  infinitePostList: IPost[];\n  infiniteUserPostList: IPost[];\n  infiniteHashTagPostList: IPost[];\n  list: IPost[];\n  data: IPost | null;\n}\n\n// Reducer\nconst initialState: IState = {\n  infinitePostList: [],\n  infiniteUserPostList: [],\n  infiniteHashTagPostList: [],\n  list: [],\n  data: null,\n};\n\nconst slice = createSlice({\n  name: POST,\n  initialState,\n  reducers: {},\n  extraReducers: (builder) =>\n    builder\n      .addCase(readPost.success, (state, { payload: data }) => {\n        state.data = data;\n      })\n      .addCase(listReadPost.success, (state, { payload: data }) => {\n        state.list = data;\n      })\n      .addCase(infinteListReadPost.success, (state, { payload: data }) => {\n        state.infinitePostList.push(...data);\n      })\n      .addCase(listReadUserPost.success, (state, { payload: data }) => {\n        state.infiniteUserPostList.push(...data);\n      })\n      .addCase(listReadHashTagPost.success, (state, { payload: data }) => {\n        state.infiniteHashTagPostList.push(...data);\n      })\n      .addCase(retweetPost.success, (state, { payload: data }) => {\n        state.infinitePostList.unshift(data);\n      })\n      .addCase(createPost.success, (state, { payload: data }) => {\n        state.infinitePostList.unshift(data);\n      })\n      .addCase(modifyPost.success, (state, { payload: data }) => {\n        const post = state.list.find((v) => v.id === data.PostId);\n        const infinitePostList = state.infinitePostList.find((v) => v.id === data.PostId);\n        const infiniteUserPostList = state.infiniteUserPostList.find((v) => v.id === data.PostId);\n        const infiniteHashTagPostList = state.infiniteHashTagPostList.find((v) => v.id === data.PostId);\n        if (post) post.content = data.content;\n        if (infinitePostList) infinitePostList.content = data.content;\n        if (infiniteUserPostList) infiniteUserPostList.content = data.content;\n        if (infiniteHashTagPostList) infiniteHashTagPostList.content = data.content;\n      })\n      .addCase(removePost.success, (state, { payload: data }) => {\n        state.list = state.list.filter((v) => v.id !== data.PostId);\n        state.infinitePostList = state.infinitePostList.filter((v) => v.id !== data.PostId);\n        state.infiniteUserPostList = state.infiniteUserPostList.filter((v) => v.id !== data.PostId);\n        state.infiniteHashTagPostList = state.infiniteHashTagPostList.filter((v) => v.id !== data.PostId);\n      })\n      .addCase(likePost.success, (state, { payload: data }) => {\n        state.list.find((v) => v.id === data.PostId)?.Likers.push({ id: data.UserId });\n        state.infinitePostList.find((v) => v.id === data.PostId)?.Likers.push({ id: data.UserId });\n        state.infiniteUserPostList.find((v) => v.id === data.PostId)?.Likers.push({ id: data.UserId });\n        state.infiniteHashTagPostList.find((v) => v.id === data.PostId)?.Likers.push({ id: data.UserId });\n      })\n      .addCase(unlikePost.success, (state, { payload: data }) => {\n        const post = state.list.find((v) => v.id === data.PostId);\n        const infinitePostList = state.infinitePostList.find((v) => v.id === data.PostId);\n        const infiniteUserPostList = state.infiniteUserPostList.find((v) => v.id === data.PostId);\n        const infiniteHashTagPostList = state.infiniteHashTagPostList.find((v) => v.id === data.PostId);\n        if (post) post.Likers = post.Likers.filter((v) => v.id !== data.UserId);\n        if (infinitePostList) infinitePostList.Likers = infinitePostList?.Likers.filter((v) => v.id !== data.UserId);\n        if (infiniteUserPostList)\n          infiniteUserPostList.Likers = infiniteUserPostList?.Likers.filter((v) => v.id !== data.UserId);\n        if (infiniteHashTagPostList)\n          infiniteHashTagPostList.Likers = infiniteHashTagPostList?.Likers.filter((v) => v.id !== data.UserId);\n      })\n      .addCase(createComment.success, (state, { payload: data }) => {\n        state.list.find((v) => v.id === data.PostId)?.Comments.unshift(data);\n        state.infinitePostList.find((v) => v.id === data.PostId)?.Comments.unshift(data);\n      })\n      .addDefaultCase((state) => state),\n});\n\nexport const postReducer = slice.reducer;\nexport const postAction = slice.actions;\n"]},"metadata":{},"sourceType":"module"}