t(/(#[^\\s#]+)/g).map((word, i) => {\n          if (word.match(/(#[^\\s#]+)/)) {\n            return (\n              <Link href={GET_HASHTAG_URL(word.slice(1))} key={i} passHref>\n                <a href={PASS_HREF}>{word}</a>\n              </Link>\n            );\n          }\n          return word;\n        })\n      )}\n    </div>\n  );\n};\n\nexport default PostCardContent;\n"]},"metadata":{},"sourceType":"module"}