Name} style={{ margin: '5px 0 5px 0' }}>\n            <img src={GET_IMAGE_URL(fileName)} alt={fileName} />\n            <div style={{ marginTop: '5px' }}>\n              <Button type=\"dashed\" onClick={handleRemoveImage(fileName)}>\n                제거\n              </Button>\n            </div>\n          </div>\n        ))}\n      </Space>\n    </Form>\n  );\n};\n\nexport default PostForm;\n"]},"metadata":{},"sourceType":"module"}