AA;AAAA;AAAA,cADD,gBAgBC;AAAA,gCACE;AAAK,UAAA,KAAK,EAAE;AAAEkC,YAAAA,KAAK,EAAE;AAAT,WAAZ;AAAA,oBAAiCpD,MAAM,CAACkB,IAAD,aAACA,IAAD,uBAACA,IAAI,CAAEmC,SAAP,CAAN,CAAwBC,MAAxB,CAA+B,YAA/B;AAAjC;AAAA;AAAA;AAAA;AAAA,gBADF,eAEE,QAAC,IAAD,CAAM,IAAN;AACE,UAAA,MAAM,eACJ,QAAC,IAAD;AAAM,YAAA,IAAI,EAAE5C,YAAY,CAACQ,IAAI,CAAC8B,IAAL,CAAU1B,EAAV,CAAaiC,QAAb,EAAD,CAAxB;AAAmD,YAAA,QAAQ,EAAE,KAA7D;AAAoE,YAAA,QAAQ,MAA5E;AAAA,mCACE;AAAG,cAAA,IAAI,EAAE5C,SAAT;AAAA,qCACE,QAAC,MAAD;AAAA,0BAASO,IAAI,CAAC8B,IAAL,CAAUE;AAAnB;AAAA;AAAA;AAAA;AAAA;AADF;AAAA;AAAA;AAAA;AAAA;AADF;AAAA;AAAA;AAAA;AAAA,kBAFJ;AAQE,UAAA,KAAK,EAAEhC,IAAI,CAAC8B,IAAL,CAAUE,QARnB;AASE,UAAA,WAAW,eAAE,QAAC,eAAD;AAAiB,YAAA,QAAQ,EAAEtB,QAA3B;AAAqC,YAAA,gBAAgB,EAAEe,oBAAvD;AAA6E,YAAA,IAAI,EAAEzB;AAAnF;AAAA;AAAA;AAAA;AAAA;AATf;AAAA;AAAA;AAAA;AAAA,gBAFF;AAAA,sBA1DJ,EAyEGQ,iBAAiB,iBAChB;AAAA,gCACE,QAAC,OAAD;AAAS,UAAA,KAAK,MAAd;AAAA,oBAAiB,GAAER,IAAI,CAACsC,QAAL,CAAcT,MAAO;AAAxC;AAAA;AAAA;AAAA;AAAA,gBADF,eAEE,QAAC,WAAD;AAAa,UAAA,IAAI,EAAE7B;AAAnB;AAAA;AAAA;AAAA;AAAA,gBAFF,EAGGE,IAAI,iBAAI,QAAC,WAAD;AAAa,UAAA,IAAI,EAAEF;AAAnB;AAAA;AAAA;AAAA;AAAA,gBAHX;AAAA;AAAA;AAAA;AAAA;AAAA,cA1EJ;AAAA;AAAA;AAAA;AAAA;AAAA;AADF;AAAA;AAAA;AAAA;AAAA,UADF;AAqFD,CAtID;;AAwIA,eAAeD,QAAf","sourcesContent":["import React, { useCallback, useMemo, useState } from 'react';\n\nimport {\n  DeleteOutlined,\n  EditOutlined,\n  EllipsisOutlined,\n  HeartOutlined,\n  HeartTwoTone,\n  MessageOutlined,\n  RetweetOutlined,\n} from '@ant-design/icons';\nimport { Card, Popover, Button, Avatar, Divider, message, Popconfirm } from 'antd';\nimport moment from 'dayjs';\nimport Link from 'next/link';\nimport { useDispatch, useSelector } from 'react-redux';\n\nimport { useFetchStatus } from '@modules/fetchStatus';\nimport { likePost, removePost, retweetPost, unlikePost } from '@modules/post';\nimport { IPost } from '@modules/post/@types/db';\nimport { userSelector } from '@modules/user';\nimport { GET_USER_URL, PASS_HREF } from '@utils/urls';\n\nimport CommentForm from './CommentForm';\nimport CommentList from './CommentList';\nimport FollowButton from './FollowButton';\nimport PostCardContent from './PostCardContent';\nimport PostImages from './PostImages';\n\nexport interface IProps {\n  data: IPost;\n}\n\nconst PostCard = ({ data }: IProps) => {\n  const dispatch = useDispatch();\n  const myId = useSelector(userSelector.myData)?.id;\n  const { status: removePostStatus } = useFetchStatus(removePost.TYPE);\n\n  const [commentFormOpened, setCommentFormOpened] = useState(false);\n  const [editMode, setEditMode] = useState(false);\n  const islike = useMemo(() => !!data.Likers.find((v) => v.id === myId)?.id, [data.Likers, myId]);\n\n  const handleRetweet = useCallback(() => {\n    if (!myId) {\n      message.warn('로그인이 필요합니다.');\n      return;\n    }\n    dispatch(retweetPost.requset({ postId: data.id }));\n  }, [data.id, dispatch, myId]);\n\n  const handleToggleLike = useMemo(\n    () => (isLike: boolean) => () => {\n      if (!myId) {\n        message.warn('로그인이 필요합니다.');\n        return;\n      }\n      if (!isLike) dispatch(likePost.requset({ postId: data.id }));\n      else dispatch(unlikePost.requset({ postId: data.id }));\n    },\n    [data.id, dispatch, myId],\n  );\n\n  const handleToggleComment = useCallback(() => {\n    setCommentFormOpened((prev) => !prev);\n  }, []);\n\n  const handleEditMode = useCallback(() => {\n    setEditMode(true);\n  }, []);\n\n  const handleCancleEditMode = useCallback(() => {\n    setEditMode(false);\n  }, []);\n\n  const handleRemovePost = useCallback(() => {\n    if (!myId) {\n      message.warn('로그인이 필요합니다.');\n      return;\n    }\n    dispatch(removePost.requset({ postId: data.id }));\n  }, [data.id, dispatch, myId]);\n\n  return (\n    <div style={{ marginBottom: 20 }}>\n      <Card\n        cover={data.Images.length && <PostImages images={data.Images} />}\n        hoverable\n        actions={[\n          <RetweetOutlined key=\"retweet\" title=\"리트윗\" onClick={handleRetweet} />,\n          islike ? (\n            <HeartTwoTone twoToneColor=\"#eb2f96\" title=\"좋아요\" key=\"heart\" onClick={handleToggleLike(islike)} />\n          ) : (\n            <HeartOutlined key=\"heart\" title=\"좋아요\" onClick={handleToggleLike(islike)} />\n          ),\n          <MessageOutlined key=\"comment\" title=\"댓글\" onClick={handleToggleComment} />,\n          <Popover\n            key=\"more\"\n            content={\n              myId &&\n              data.User.id === myId && (\n                <Button.Group>\n                  {!data.RetweetId && (\n                    <Button onClick={handleEditMode}>\n                      <EditOutlined /> 수정\n                    </Button>\n                  )}\n                  <Popconfirm\n                    title=\"Are you sure delete this Post?\"\n                    okText=\"Yes\"\n                    onConfirm={handleRemovePost}\n                    cancelText=\"No\"\n                  >\n                    <Button type=\"dager\" loading={removePostStatus === 'LOADING'}>\n                      <DeleteOutlined /> 삭제\n                    </Button>\n                  </Popconfirm>\n                </Button.Group>\n              )\n            }\n          >\n            <EllipsisOutlined />\n          </Popover>,\n        ]}\n        title={data.RetweetId && `${data.User.nickname}님이 리트윗하셨습니다.`}\n        extra={myId && data.User.id !== myId && <FollowButton data={data} />}\n      >\n        {data.Retweet ? (\n          <Card cover={data.Retweet.Images[0] && <PostImages images={data.Retweet.Images} />}>\n            <div style={{ float: 'right' }}>{moment(data.createdAt).format('YYYY.MM.DD')}</div>\n            <Card.Meta\n              avatar={\n                <Link href={GET_USER_URL(data.Retweet.User.id.toString())} prefetch={false} passHref>\n                  <a href={PASS_HREF}>\n                    <Avatar>{data.Retweet.User.nickname}</Avatar>\n                  </a>\n                </Link>\n              }\n              title={data.Retweet.User.nickname}\n              description={<PostCardContent onCancleEditMode={handleCancleEditMode} data={data} />}\n            />\n          </Card>\n        ) : (\n          <>\n            <div style={{ float: 'right' }}>{moment(data?.createdAt).format('YYYY.MM.DD')}</div>\n            <Card.Meta\n              avatar={\n                <Link href={GET_USER_URL(data.User.id.toString())} prefetch={false} passHref>\n                  <a href={PASS_HREF}>\n                    <Avatar>{data.User.nickname}</Avatar>\n                  </a>\n                </Link>\n              }\n              title={data.User.nickname}\n              description={<PostCardContent editMode={editMode} onCancleEditMode={handleCancleEditMode} data={data} />}\n            />\n          </>\n        )}\n        {commentFormOpened && (\n          <div>\n            <Divider plain>{`${data.Comments.length}개의 댓글`}</Divider>\n            <CommentList data={data} />\n            {myId && <CommentForm data={data} />}\n          </div>\n        )}\n      </Card>\n    </div>\n  );\n};\n\nexport default PostCard;\n"]},"metadata":{},"sourceType":"module"}